# T-MAC Full Inference Docker (ARM64 native on Apple Silicon)
FROM --platform=linux/arm64 ubuntu:22.04

LABEL maintainer="FPGA Development"
LABEL description="T-MAC LLM Inference Runtime"

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    g++ \
    python3 \
    python3-pip \
    git \
    wget \
    file \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY models/ /workspace/models/
COPY firmware/ /workspace/firmware/
COPY scripts/ /workspace/scripts/
COPY sim/ /workspace/sim/

RUN echo "=== Building T-MAC Firmware ===" && \
    cd /workspace/sim && \
    g++ -O2 -march=armv8-a -o tmac_test tmac_test.cpp -lm && \
    file tmac_test && \
    echo "Build complete!"

CMD ["/bin/bash"]
